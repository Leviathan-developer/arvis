# === GENERAL ===
ARVIS_DATA_DIR=./data                    # Where to store DB, logs, backups (default: ./data)

# === LLM ACCOUNTS (at least one required) ===
# You can configure multiple providers. Arvis will automatically rotate
# between accounts and silently switch on rate limits.

# --- Anthropic CLI Subscription ---
# RECOMMENDED: Use `npm run add-account` to set up accounts.
# Accounts in data/accounts/ are auto-detected — no env vars needed.
#
# MANUAL OVERRIDE (optional, supports indexed: _1, _2, ... up to 50):
# CLAUDE_CLI_HOME=                       # Primary account home dir
# CLAUDE_CLI_HOME_1=                     # Second subscription account home dir
CLAUDE_CLI_MODEL=claude-sonnet-4-6       # Default model for all CLI accounts

# --- Anthropic API (supports indexed: _1, _2, ... up to 50) ---
ANTHROPIC_API_KEY=                       # Anthropic API key
ANTHROPIC_API_KEY_1=                     # Additional Anthropic API key
ANTHROPIC_API_KEY_2=                     # Additional Anthropic API key
ANTHROPIC_API_MODEL=claude-haiku-4-5-20251001

# --- OpenAI (supports indexed: _1, _2, ...) ---
OPENAI_API_KEY=                          # OpenAI API key
OPENAI_MODEL=gpt-4o-mini

# --- OpenRouter (supports indexed: _1, _2, ...) ---
OPENROUTER_API_KEY=                      # OpenRouter API key
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# --- Google Gemini (supports indexed: _1, _2, ...) ---
GOOGLE_API_KEY=                          # Google AI API key
GOOGLE_MODEL=gemini-2.0-flash

# --- Ollama (local, no key needed) ---
OLLAMA_BASE_URL=                         # e.g., http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:7b

# === CONNECTORS (all optional — add whichever platforms you use) ===
DISCORD_TOKEN=                           # Discord bot token
DISCORD_OWNER_ID=                        # Your Discord user ID (for DM routing)

TELEGRAM_BOT_TOKEN=                      # Telegram bot token (from @BotFather)

# Slack (Socket Mode — no public URL needed)
SLACK_BOT_TOKEN=                         # xoxb-... Bot User OAuth Token
SLACK_APP_TOKEN=                         # xapp-... App-Level Token (for Socket Mode)
SLACK_SIGNING_SECRET=                    # Signing secret from Slack app settings

# WhatsApp Business (Cloud API via Meta)
WHATSAPP_ACCESS_TOKEN=                   # Permanent access token from Meta
WHATSAPP_PHONE_NUMBER_ID=               # Phone number ID from WhatsApp Business
WHATSAPP_VERIFY_TOKEN=                   # Your custom verify token for webhook setup
WHATSAPP_WEBHOOK_PATH=/whatsapp          # Webhook path (appended to webhook server)

# Matrix (Element/Synapse)
MATRIX_HOMESERVER_URL=                   # e.g., https://matrix.org
MATRIX_ACCESS_TOKEN=                     # Bot account access token
MATRIX_USER_ID=                          # e.g., @arvis:matrix.org

# Web Chat
WEB_CONNECTOR_PORT=5070                  # Port for web chat WebSocket
WEB_API_KEY=                             # API key for web connector (optional)

# === DASHBOARD ===
DASHBOARD_PORT=5100                      # Web dashboard port

# Security — leave blank for homeserver mode (open access on localhost)
# Set DASHBOARD_PASSWORD to enable login gate (required for VPS / public exposure)
DASHBOARD_PASSWORD=                      # Dashboard login password (activates auth gate)

# API key for programmatic access (scripts, bots, external integrations)
# Generate: openssl rand -hex 32
# Usage: Authorization: Bearer <key>  or  X-API-Key: <key>
DASHBOARD_API_KEY=                       # Optional API key for bearer token auth

# JWT signing secret — auto-generated on first run if not set
# Pin this on VPS so sessions survive restarts
JWT_SECRET=                              # 32+ random bytes (openssl rand -hex 32)

# Docker sandbox for CLI agents (optional)
ARVIS_SANDBOX_IMAGE=arvis-sandbox:latest  # Docker image for agent sandboxing

# === WEBHOOKS ===
WEBHOOK_PORT=5050                        # Port for incoming webhooks
WEBHOOK_SECRET=                          # Default webhook secret

# === MISC ===
LOG_LEVEL=info                           # debug, info, warn, error
TIMEZONE=UTC                             # Default timezone
CONDUCTOR_CHANNEL=                       # Discord channel ID for the conductor agent (optional)
